# ============================================================
# Runtime state — never commit
# ============================================================
claude/projects/
claude/sessions/
claude/todos/
claude/tasks/
claude/cache/
claude/paste-cache/
claude/shell-snapshots/
claude/telemetry/
claude/logs/
claude/file-history/
claude/ide/
claude/session-env/
claude/debug/
claude/backups/
claude/history.jsonl
claude/*-cache.json

# ============================================================
# Plugins — reinstalled via bootstrap (don't commit binaries)
# ============================================================
claude/plugins/

# ============================================================
# Backups
# ============================================================
*.bak
*.bak.*

# ============================================================
# Secrets — populated from SECRETS.md transfer, never commit
# ============================================================
.env
.env.local
secrets.env
SECRETS.md
claude/.env
claude/settings.json
claude/settings.local.json
claude/.mcp.json

# ============================================================
# OS / editor noise
# ============================================================
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# ============================================================
# Node / Python ephemera (in case skills bring any in)
# ============================================================
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# ============================================================
# gstack vendored build artifacts (regenerated by `bun run build`)
# ============================================================
claude/skills/gstack/browse/dist/
claude/skills/gstack/.gstack-cache/
claude/skills/gstack/bun.lock
claude/skills/gstack/.bun-build/

# ============================================================
# Claude Code's own runtime state at repo root
# ============================================================
.planning/
.letta/
.claude/
