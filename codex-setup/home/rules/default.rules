prefix_rule(pattern=["/bin/zsh", "-lc", "for s in autoresearch build-with-agent-team gstack ingest lint sync-vault vault-save; do cp \"codex-from-claude/home/skills/$s/SKILL.md\" \"$HOME/.codex/skills/$s/SKILL.md\"; done"], decision="allow")
