# Runtime artifacts that get regenerated by background plugins. Never commit.
.letta/
.planning/

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
*.swo

# Backups produced by setup-codex.sh / setup-codex.ps1 if accidentally placed inside the repo
*.bak
*.bak.*

# windows-claude-code/ has its own .gitignore (CC-specific runtime exclusions).
